<Page
    x:Class="WolffilesUploader.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgSurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Topbar -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource BgElevatedBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <TextBlock Text="Einstellungen"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="12" MaxWidth="600" HorizontalAlignment="Left">

                <!-- Account -->
                <TextBlock Text="ACCOUNT" FontSize="11" FontFamily="Consolas"
                           Foreground="#424860" CharacterSpacing="100" Margin="0,8,0,0" />

                <Border Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="#22263A" BorderThickness="1"
                        CornerRadius="7" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                Background="{StaticResource AccentGoldBrush}"
                                Margin="0,0,14,0">
                            <TextBlock x:Name="AvatarText"
                                       FontWeight="Bold" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#0F1117" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="UserNameText"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock x:Name="UserRoleText"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       CharacterSpacing="50" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="Ausloggen"
                                VerticalAlignment="Center"
                                Click="Logout_Click" />
                    </Grid>
                </Border>

                <!-- Sprache -->
                <TextBlock Text="SPRACHE / LANGUAGE / LANGUE"
                           FontSize="11" FontFamily="Consolas"
                           Foreground="#424860" CharacterSpacing="100" Margin="0,8,0,0" />

                <Border Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="#22263A" BorderThickness="1"
                        CornerRadius="7" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Sprache der App"
                                   FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" />
                        <ComboBox x:Name="LanguageCombo"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="LanguageCombo_SelectionChanged">
                            <ComboBoxItem Tag="de-DE" Content="🇩🇪  Deutsch" />
                            <ComboBoxItem Tag="en-US" Content="🇬🇧  English" />
                            <ComboBoxItem Tag="fr-FR" Content="🇫🇷  Français" />
                        </ComboBox>
                        <TextBlock Text="Sprachänderung wird nach Neustart der App aktiv."
                                   FontSize="11" FontFamily="Consolas"
                                   Foreground="#424860" />
                    </StackPanel>
                </Border>

                <!-- Version & Update -->
                <TextBlock Text="VERSION &amp; UPDATE"
                           FontSize="11" FontFamily="Consolas"
                           Foreground="#424860" CharacterSpacing="100" Margin="0,8,0,0" />

                <Border Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="#22263A" BorderThickness="1"
                        CornerRadius="7" Padding="16">
                    <StackPanel Spacing="10">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Wolffiles Uploader"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock x:Name="VersionText"
                                           FontSize="11" FontFamily="Consolas"
                                           Foreground="#424860" />
                            </StackPanel>
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Content="Auf Updates prüfen"
                                    Click="CheckUpdate_Click" />
                        </Grid>

                        <Border x:Name="UpdateBanner"
                                Background="#1AC8A84B"
                                BorderBrush="{StaticResource AccentGoldBrush}"
                                BorderThickness="1" CornerRadius="5"
                                Padding="12,8" Visibility="Collapsed">
                            <Grid>
                                <TextBlock x:Name="UpdateText"
                                           FontSize="12"
                                           Foreground="{StaticResource AccentGoldBrush}"
                                           VerticalAlignment="Center" />
                                <Button x:Name="UpdateBtn"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Content="Herunterladen"
                                        Click="Update_Click" />
                            </Grid>
                        </Border>

                        <TextBlock x:Name="UpToDateText"
                                   Text="✓ Du nutzt die neueste Version"
                                   FontSize="11" FontFamily="Consolas"
                                   Foreground="{StaticResource StatusGreenBrush}"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- Links -->
                <TextBlock Text="LINKS"
                           FontSize="11" FontFamily="Consolas"
                           Foreground="#424860" CharacterSpacing="100" Margin="0,8,0,0" />

                <Border Background="{StaticResource BgElevatedBrush}"
                        BorderBrush="#22263A" BorderThickness="1"
                        CornerRadius="7" Padding="16">
                    <StackPanel Spacing="8">
                        <HyperlinkButton Content="🌐  wolffiles.eu öffnen"
                                         NavigateUri="https://wolffiles.eu"
                                         Foreground="{StaticResource TextSecondaryBrush}" />
                        <HyperlinkButton Content="🐛  Bug melden / Feedback"
                                         NavigateUri="https://wolffiles.eu/contact"
                                         Foreground="{StaticResource TextSecondaryBrush}" />
                        <HyperlinkButton Content="📦  GitHub Releases"
                                         NavigateUri="https://github.com/wolffileseu/wolffiles-uploader/releases"
                                         Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
