<Page
    x:Class="WolffilesUploader.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:WolffilesUploader.Models"
    Background="{StaticResource BgSurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Topbar -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource BgElevatedBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <TextBlock Text="Upload History"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="🗑 Verlauf löschen"
                            Command="{x:Bind ViewModel.ClearHistoryCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="12">

                <!-- Stats -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="#22263A" BorderThickness="1"
                            CornerRadius="7" Padding="14,12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="GESAMT UPLOADS" FontSize="10" FontFamily="Consolas"
                                       Foreground="#424860" CharacterSpacing="80" />
                            <TextBlock Text="{x:Bind ViewModel.Stats.TotalUploads, Mode=OneWay}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGoldBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="#22263A" BorderThickness="1"
                            CornerRadius="7" Padding="14,12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="HOCHGELADEN" FontSize="10" FontFamily="Consolas"
                                       Foreground="#424860" CharacterSpacing="80" />
                            <TextBlock Text="{x:Bind ViewModel.Stats.TotalSizeDisplay, Mode=OneWay}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="#22263A" BorderThickness="1"
                            CornerRadius="7" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="ERFOLGREICH" FontSize="10" FontFamily="Consolas"
                                       Foreground="#424860" CharacterSpacing="80" />
                            <TextBlock Text="{x:Bind ViewModel.Stats.SuccessCount, Mode=OneWay}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource StatusGreenBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,40,0,0"
                            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="📭" FontSize="36" HorizontalAlignment="Center" Opacity="0.3" />
                    <TextBlock Text="Noch keine Uploads"
                               FontSize="13" Foreground="#424860"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- History list -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:HistoryItem">
                            <Border Background="{StaticResource BgElevatedBrush}"
                                    BorderBrush="#22263A" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="32" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind FileName}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Category}"
                                               FontSize="11" FontFamily="Consolas"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind FileSizeDisplay}"
                                               FontSize="11" FontFamily="Consolas"
                                               Foreground="#424860"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind DateDisplay}"
                                               FontSize="11" FontFamily="Consolas"
                                               Foreground="#424860"
                                               VerticalAlignment="Center" />

                                    <!-- Status badge -->
                                    <Border Grid.Column="4" CornerRadius="3" Padding="6,2"
                                            VerticalAlignment="Center"
                                            Background="{x:Bind Success,
                                                Converter={StaticResource BoolToStatusBgConverter}}">
                                        <TextBlock FontSize="10" FontFamily="Consolas" FontWeight="SemiBold"
                                                   Text="{x:Bind Success,
                                                       Converter={StaticResource BoolToStatusTextConverter}}"
                                                   Foreground="{x:Bind Success,
                                                       Converter={StaticResource BoolToStatusFgConverter}}" />
                                    </Border>

                                    <!-- Link button -->
                                    <Button Grid.Column="5"
                                            Content="🔗"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Padding="4,2"
                                            Visibility="{x:Bind Url,
                                                Converter={StaticResource StringToVisibilityConverter}}"
                                            Tag="{x:Bind Url}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
