<Page
    x:Class="WolffilesUploader.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBaseBrush}">

    <NavigationView x:Name="NavView"
                    PaneDisplayMode="Left"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    CompactModeThresholdWidth="0"
                    OpenPaneLength="210"
                    Background="{StaticResource BgBaseBrush}"
                    ItemInvoked="NavView_ItemInvoked">

        <!-- User header in pane -->
        <NavigationView.PaneHeader>
            <Border BorderBrush="{StaticResource BgElevatedBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,12,12,12"
                    Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="34" Height="34" CornerRadius="6"
                            Background="{StaticResource AccentGoldBrush}">
                        <TextBlock x:Name="AvatarInitial"
                                   FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#0F1117" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="UserNameText"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock x:Name="UserRoleText"
                                   FontSize="10" FontFamily="Consolas"
                                   Foreground="{StaticResource AccentGoldBrush}"
                                   CharacterSpacing="50" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </NavigationView.PaneHeader>

        <!-- Nav items -->
        <NavigationView.MenuItems>
            <NavigationViewItem Tag="queue" Icon="Upload" Content="Upload Queue">
                <NavigationViewItem.InfoBadge>
                    <InfoBadge x:Name="QueueBadge"
                               Value="0"
                               Style="{StaticResource AttentionValueInfoBadgeStyle}"
                               Visibility="Collapsed" />
                </NavigationViewItem.InfoBadge>
            </NavigationViewItem>
            <NavigationViewItem Tag="history" Icon="Clock" Content="History" />
        </NavigationView.MenuItems>

        <!-- Footer -->
        <NavigationView.FooterMenuItems>
            <NavigationViewItem Tag="settings" Icon="Setting" Content="Einstellungen" />
            <NavigationViewItem Tag="logout" Icon="LeaveChat" Content="Ausloggen" />
        </NavigationView.FooterMenuItems>

        <!-- Content frame -->
        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Page>
