<Page
    x:Class="WolffilesUploader.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBaseBrush}">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
        <StackPanel Spacing="0">

            <!-- Logo -->
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                <TextBlock Text="🐺 WOLFFILES"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           FontFamily="Rajdhani, Segoe UI" />
                <TextBlock x:Name="VersionText"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Card -->
            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BgElevatedBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="32">
                <StackPanel Spacing="16">

                    <!-- Error banner -->
                    <InfoBar x:Name="ErrorBar"
                             Severity="Error"
                             IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                             IsClosable="False" />

                    <!-- Email -->
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="LoginEmailLabel"
                                   FontSize="11" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   CharacterSpacing="80" />
                        <TextBox x:Name="EmailBox"
                                 Text="{x:Bind ViewModel.Email, Mode=TwoWay}"
                                 KeyDown="TextBox_KeyDown" />
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="LoginPasswordLabel"
                                   FontSize="11" FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   CharacterSpacing="80" />
                        <PasswordBox x:Name="PasswordBox"
                                     PlaceholderText="••••••••"
                                     Password="{x:Bind ViewModel.Password, Mode=TwoWay}"
                                     KeyDown="PasswordBox_KeyDown" />
                    </StackPanel>

                    <!-- Remember Me -->
                    <CheckBox x:Name="LoginRememberCheckbox"
                              IsChecked="{x:Bind ViewModel.RememberMe, Mode=TwoWay}"
                              Foreground="{StaticResource TextSecondaryBrush}" />

                    <!-- Login Button -->
                    <Button Command="{x:Bind ViewModel.LoginCommand}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource AccentButtonStyle}"
                            Margin="0,8,0,0">
                        <Grid>
                            <TextBlock x:Name="LoginSubmitText"
                                       FontWeight="SemiBold"
                                       FontFamily="Consolas"
                                       CharacterSpacing="120"
                                       Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToInverseVisibilityConverter}, Mode=OneWay}" />
                            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                          Width="20" Height="20" />
                        </Grid>
                    </Button>

                    <!-- Register hint -->
                    <HyperlinkButton x:Name="LoginRegisterLink"
                                     NavigateUri="https://wolffiles.eu/register"
                                     HorizontalAlignment="Center"
                                     FontSize="11"
                                     Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
