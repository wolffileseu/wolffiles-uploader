<Application
    x:Class="WolffilesUploader.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:WolffilesUploader.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Brushes -->
            <SolidColorBrush x:Key="AccentGoldBrush"    Color="#C8A84B" />
            <SolidColorBrush x:Key="BgBaseBrush"        Color="#0F1117" />
            <SolidColorBrush x:Key="BgSurfaceBrush"     Color="#161B26" />
            <SolidColorBrush x:Key="BgElevatedBrush"    Color="#1E2436" />
            <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#E8E8F0" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#7A8099" />
            <SolidColorBrush x:Key="StatusGreenBrush"   Color="#52C98A" />
            <SolidColorBrush x:Key="StatusRedBrush"     Color="#E05252" />
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#161B26" />

            <!-- Converters -->
            <conv:BoolToVisibilityConverter         x:Key="BoolToVisibilityConverter" />
            <conv:BoolToInverseVisibilityConverter  x:Key="BoolToInverseVisibilityConverter" />
            <conv:StringToVisibilityConverter       x:Key="StringToVisibilityConverter" />
            <conv:StatusToStringConverter           x:Key="StatusToStringConverter" />
            <conv:StatusToUploadingVisibilityConverter x:Key="StatusToUploadingVisibilityConverter" />
            <conv:BoolToStatusBgConverter           x:Key="BoolToStatusBgConverter" />
            <conv:BoolToStatusFgConverter           x:Key="BoolToStatusFgConverter" />
            <conv:BoolToStatusTextConverter         x:Key="BoolToStatusTextConverter" />
            <conv:BoolToFontWeightConverter         x:Key="BoolToFontWeightConverter" />
            <conv:BoolToForegroundConverter         x:Key="BoolToForegroundConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
